# Copie ce fichier :  cp .env.example .env   — puis renseigne les valeurs.
# Le .env est ignoré par git : les secrets ne sont jamais committés.

# ── LLM ─────────────────────────────────────────────────────────────
# Format : "<provider>:<model>" — ex. "openai:gpt-4o-mini", "anthropic:claude-sonnet-5"
LLM_MODEL=openai:gpt-4o-mini
OPENAI_API_KEY=sk-...
# Embeddings du RAG (OpenAI)
EMBEDDINGS_MODEL=text-embedding-3-small

# ── Spotify (voir README §2.2 : https://developer.spotify.com/dashboard) ─
SPOTIPY_CLIENT_ID=ton_client_id
SPOTIPY_CLIENT_SECRET=ton_client_secret
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# ── Chemins (défauts corrects, ne changer qu'en connaissance de cause) ─
DATA_DIR=data
VECTORSTORE_DIR=vectorstore

# ── Logs ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
